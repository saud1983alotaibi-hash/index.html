<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<title>منظومة المحامي سعود | الإصدار المتكامل</title>
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --ink:#0a0e17; --ink2:#111827; --ink3:#1a2233;
  --card:#1c2540; --card2:#222d48;
  --rim:rgba(255,255,255,0.07); --rim2:rgba(255,255,255,0.12);
  --gold:#c9a84c; --gold2:#e8c870;
  --gold-dim:rgba(201,168,76,0.15); --gold-rim:rgba(201,168,76,0.3);
  --text:#eef2ff; --text2:#94a3c0; --text3:#5a6a88;
  --safe-top:env(safe-area-inset-top,44px);
  --safe-bottom:env(safe-area-inset-bottom,20px);
}
body.day {
  --ink:#f0f4ff; --ink2:#e2e8f8; --ink3:#d8dfee;
  --card:#ffffff; --card2:#f5f8ff;
  --rim:rgba(0,0,0,0.07); --rim2:rgba(0,0,0,0.12);
  --text:#0a0e17; --text2:#334155; --text3:#64748b;
}
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent; }
html, body { height:100%; background:var(--ink); overflow:hidden; font-family:'IBM Plex Sans Arabic',sans-serif; color:var(--text); direction:rtl; transition:all .3s; }

#app { display:flex; flex-direction:column; height:100vh; height:100dvh; max-width:430px; margin:0 auto; background:var(--ink); }
#hdr { flex-shrink:0; padding-top:var(--safe-top); background:var(--ink); z-index:40; border-bottom:1px solid var(--rim); }
.hi { display:flex; align-items:center; justify-content:space-between; padding:12px 18px; }
.ht { font-family:'Amiri',serif; font-size:21px; font-weight:700; color:var(--gold2); }
.ha { display:flex; gap:6px; }
.bi { width:34px; height:34px; border-radius:10px; background:var(--card); border:1px solid var(--rim2); display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:16px; }
.bn { background:var(--gold); color:var(--ink); border-radius:12px; padding:8px 14px; font-size:12px; font-weight:700; cursor:pointer; border:none; }

.ts { display:flex; padding:8px; gap:4px; overflow-x:auto; background:var(--ink); }
.ts::-webkit-scrollbar { display:none; }
.tp { flex-shrink:0; padding:8px 14px; border-radius:10px; color:var(--text3); font-size:11px; font-weight:600; cursor:pointer; border:1px solid transparent; white-space:nowrap; transition:0.2s; }
.tp.on { background:var(--gold-dim); color:var(--gold2); border-color:var(--gold-rim); }

#cnt { flex:1; overflow-y:auto; padding:15px; }

/* بطاقات القضايا */
.card { background:var(--card); border:1px solid var(--rim); border-radius:18px; padding:16px; margin-bottom:12px; position:relative; overflow:hidden; }
.card::after { content:''; position:absolute; right:0; top:0; width:4px; height:100%; background:var(--gold); }
.ct { display:flex; justify-content:space-between; margin-bottom:8px; }
.cn { font-family:'Amiri',serif; font-size:18px; font-weight:700; color:var(--gold2); }
.ctp { font-size:11px; color:var(--text3); margin-top:4px; }
.ctm { font-size:16px; font-weight:bold; color:var(--text); text-align:left; }

/* المهمات والأطراف */
.list-item { background:var(--card2); border:1px solid var(--rim); border-radius:12px; padding:12px; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center; }
.check { width:20px; height:20px; border-radius:6px; border:2px solid var(--gold2); cursor:pointer; }
.check.done { background:var(--gold2); position:relative; }
.check.done::after { content:'✓'; position:absolute; top:-2px; right:2px; color:var(--ink); font-weight:bold; }

/* القوالب والنوافذ */
.ov { position:fixed; inset:0; z-index:100; display:flex; flex-direction:column; justify-content:flex-end; transition:0.3s; }
.ov.hid { visibility:hidden; opacity:0; pointer-events:none; }
.ob { position:absolute; inset:0; background:rgba(0,0,0,0.7); backdrop-filter:blur(4px); }
.sheet { position:relative; background:var(--card); border-radius:24px 24px 0 0; padding:24px; max-height:85vh; overflow-y:auto; border-top:1px solid var(--rim2); transform:translateY(0); transition:0.3s ease-out; }
.ov.hid .sheet { transform:translateY(100%); }

.field { margin-bottom:15px; }
.field label { display:block; font-size:11px; color:var(--text3); margin-bottom:6px; font-weight:bold; }
.field input, .field select, .field textarea { width:100%; background:var(--ink3); border:1px solid var(--rim2); border-radius:12px; padding:12px; color:var(--text); font-family:inherit; }

.bg-btn { width:100%; background:var(--gold); color:var(--ink); border-radius:14px; padding:15px; font-weight:bold; cursor:pointer; border:none; margin-top:10px; }

/* الإحصائيات */
.stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:20px; }
.stat-box { background:var(--card2); border:1px solid var(--rim); border-radius:16px; padding:15px; text-align:center; }
.stat-num { font-size:24px; font-weight:bold; color:var(--gold2); }
.stat-label { font-size:10px; color:var(--text3); margin-top:4px; }
</style>
</head>
<body>

<div id="app">
  <div id="hdr">
    <div class="hi">
      <div class="ht">مكتب المحامي سعود ⚖️</div>
      <div class="ha">
        <button class="bi" onclick="toggleTheme()">🌓</button>
        <button class="bn" onclick="openModal('session')">+ إضافة</button>
      </div>
    </div>
    <div class="ts">
      <button class="tp on" id="t-home" onclick="go('home')">الرئيسية</button>
      <button class="tp" id="t-list" onclick="go('list')">الجلسات</button>
      <button class="tp" id="t-tasks" onclick="go('tasks')">المهمات</button>
      <button class="tp" id="t-people" onclick="go('people')">الأطراف</button>
      <button class="tp" id="t-stats" onclick="go('stats')">التقارير</button>
    </div>
  </div>

  <div id="cnt"></div>
</div>

<div class="ov hid" id="modal">
  <div class="ob" onclick="closeModal()"></div>
  <div class="sheet" id="modal-content"></div>
</div>

<script>
// --- قاعدة البيانات المحسنة ---
let state = {
  sessions: JSON.parse(localStorage.getItem('saud_s') || '[]'),
  tasks: JSON.parse(localStorage.getItem('saud_t') || '[]'),
  people: JSON.parse(localStorage.getItem('saud_p') || '[]'),
  currentTab: 'home'
};

function save() {
  localStorage.setItem('saud_s', JSON.stringify(state.sessions));
  localStorage.setItem('saud_t', JSON.stringify(state.tasks));
  localStorage.setItem('saud_p', JSON.stringify(state.people));
  render();
}

// --- التنقل ---
function go(tab) {
  state.currentTab = tab;
  document.querySelectorAll('.tp').forEach(btn => btn.classList.toggle('on', btn.id === 't-'+tab));
  render();
}

function render() {
  const cnt = document.getElementById('cnt');
  if (state.currentTab === 'home') renderHome(cnt);
  if (state.currentTab === 'list') renderList(cnt);
  if (state.currentTab === 'tasks') renderTasks(cnt);
  if (state.currentTab === 'people') renderPeople(cnt);
  if (state.currentTab === 'stats') renderStats(cnt);
}

// --- الواجهة الرئيسية ---
function renderHome(cnt) {
  const today = new Date().toISOString().split('T')[0];
  const upcoming = state.sessions.filter(s => s.date >= today).sort((a,b) => a.date.localeCompare(b.date));
  
  let h = `<div style="font-size:12px; color:var(--text3); margin-bottom:15px">الجلسات القادمة اليوم وقريباً</div>`;
  if(upcoming.length === 0) h += `<div style="text-align:center; padding:40px; color:var(--text3)">لا توجد جلسات مجدولة</div>`;
  
  upcoming.forEach((s, i) => {
    h += `<div class="card">
      <div class="ct">
        <div>
          <div class="cn">${s.num}</div>
          <div class="ctp">🏛️ ${s.court} | ${s.type}</div>
        </div>
        <div class="ctm">${s.time}<br><small style="font-size:10px; font-weight:normal; color:var(--text3)">${s.date}</small></div>
      </div>
      <div style="font-size:11px; color:var(--text2); background:var(--ink3); padding:8px; border-radius:8px; margin-top:8px">
        👤 الخصم: ${s.dfnd || 'غير محدد'}
      </div>
    </div>`;
  });
  cnt.innerHTML = h;
}

// --- إدارة المهمات ---
function renderTasks(cnt) {
  let h = `
    <div style="display:flex; gap:8px; margin-bottom:15px">
      <input type="text" id="tInp" placeholder="أضف مهمة جديدة (مثلاً: كتابة لائحة)" style="flex:1; background:var(--card); border:1px solid var(--rim2); border-radius:12px; padding:12px; color:var(--text)">
      <button class="bn" onclick="addTask()">إضافة</button>
    </div>
  `;
  state.tasks.forEach((t, i) => {
    h += `
      <div class="list-item">
        <div style="display:flex; align-items:center; gap:12px">
          <div class="check ${t.done?'done':''}" onclick="toggleTask(${i})"></div>
          <span style="font-size:14px; ${t.done?'text-decoration:line-through; opacity:0.5':''}">${t.title}</span>
        </div>
        <button onclick="delItem('tasks', ${i})" style="color:var(--text3); background:none; border:none">✕</button>
      </div>
    `;
  });
  cnt.innerHTML = h || '<div style="text-align:center; padding:40px">أضف مهامك المكتبية هنا</div>';
}

function addTask() {
  const val = document.getElementById('tInp').value;
  if(!val) return;
  state.tasks.push({title: val, done: false});
  save();
}

function toggleTask(i) { state.tasks[i].done = !state.tasks[i].done; save(); }

// --- النوافذ المنبثقة ---
function openModal(type) {
  const m = document.getElementById('modal-content');
  if(type === 'session') {
    m.innerHTML = `
      <h2 style="font-family:'Amiri',serif; color:var(--gold2); margin-bottom:20px">إضافة قضية جديدة</h2>
      <div class="field"><label>رقم القضية</label><input type="text" id="fNum" placeholder="2024/0000"></div>
      <div class="field"><label>المحكمة</label><input type="text" id="fCourt" placeholder="المحكمة العامة"></div>
      <div class="field"><label>نوع القضية</label>
        <select id="fType"><option>حقوقية</option><option>جنائية</option><option>تجارية</option><option>عمالية</option></select>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px">
        <div class="field"><label>التاريخ</label><input type="date" id="fDate"></div>
        <div class="field"><label>الوقت</label><input type="time" id="fTime"></div>
      </div>
      <div class="field"><label>اسم الخصم</label><input type="text" id="fDfnd"></div>
      <button class="bg-btn" onclick="saveSession()">حفظ في المنظومة</button>
    `;
  }
  document.getElementById('modal').classList.remove('hid');
}

function saveSession() {
  const s = {
    num: document.getElementById('fNum').value,
    court: document.getElementById('fCourt').value,
    type: document.getElementById('fType').value,
    date: document.getElementById('fDate').value,
    time: document.getElementById('fTime').value,
    dfnd: document.getElementById('fDfnd').value
  };
  if(!s.num || !s.date) return alert("يرجى إكمال البيانات الأساسية");
  state.sessions.push(s);
  save();
  closeModal();
  go('home');
}

function closeModal() { document.getElementById('modal').classList.add('hid'); }
function toggleTheme() { document.body.classList.toggle('day'); }
function delItem(key, i) { if(confirm('هل أنت متأكد؟')) { state[key].splice(i,1); save(); } }

// --- الإحصائيات ---
function renderStats(cnt) {
  const total = state.sessions.length;
  const doneTasks = state.tasks.filter(t => t.done).length;
  cnt.innerHTML = `
    <h2 style="font-family:'Amiri',serif; color:var(--gold2); margin-bottom:20px">تقرير أداء المكتب 📊</h2>
    <div class="stats-grid">
      <div class="stat-box"><div class="stat-num">${total}</div><div class="stat-label">إجمالي القضايا</div></div>
      <div class="stat-box"><div class="stat-num">${state.tasks.length}</div><div class="stat-label">مهمات مكتبية</div></div>
      <div class="stat-box"><div class="stat-num">${doneTasks}</div><div class="stat-label">مهام منجزة</div></div>
      <div class="stat-box"><div class="stat-num">${state.people.length}</div><div class="stat-label">عدد الأطراف</div></div>
    </div>
    <div style="background:var(--card2); padding:15px; border-radius:15px; font-size:12px; line-height:1.6">
      أستاذ سعود، المنظومة تعمل الآن بكفاءة. لديك ${state.tasks.length - doneTasks} مهمة معلقة تتطلب اهتمامك.
    </div>
  `;
}

// البداية
window.onload = render;
</script>
</body>
</html>
